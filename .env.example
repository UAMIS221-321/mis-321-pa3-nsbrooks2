# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="AI_KEY_HERE"

# MYSQL_CONNECTION_STRING: Connection string for your MySQL database.
# Example: Server=hostname;Database=db;Uid=user;Pwd=pass
MYSQL_CONNECTION_STRING="YOUR_CONNECTION_STRING_HERE"

# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_URL_HERE"
